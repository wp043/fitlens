{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rewriteRelativeImportExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "erasableSyntaxOnly": true,
    "declaration": false,
    "sourceMap": true,
    "noEmit": false,
    "incremental": false,
    "outDir": "dist",
    "rootDir": "."
  },
  "files": ["scripts/fitlens.ts"]
}

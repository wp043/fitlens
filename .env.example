# FitLens uses one model provider per run. Configure OpenAI or Anthropic.
# If only one key is set, that provider is used automatically.

# --- OpenAI (default when OPENAI_API_KEY is set) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# --- Anthropic (used automatically when only ANTHROPIC_API_KEY is set) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Force a provider when both keys are present: openai | anthropic | compatible
# FITLENS_MODEL_PROVIDER=anthropic

# Optional: an OpenAI-compatible Responses API instead (e.g. a local server).
# FITLENS_MODEL_PROVIDER=compatible
# FITLENS_MODEL_BASE_URL=http://127.0.0.1:11434/v1
# FITLENS_MODEL_MODEL=your-structured-output-model
# FITLENS_MODEL_API_KEY=

# Optional: raises GitHub API rate limits for repository enrichment.
GITHUB_TOKEN=
FITLENS_BROWSER_FALLBACK=0
